generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  operations_manager
  sales
  finance
  operations
  client_admin
  client_team
  client_viewer
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal_sent
  negotiation
  closed_won
  closed_lost
  onboarding
  active_client
  upsell_opportunity
  at_risk_churn
  churned
}

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum ContractStatus {
  draft
  pending_signature
  active
  paused
  cancelled
  finished
}

enum ClientStatus {
  active
  inactive
  blocked
}

enum ClientHealth {
  thriving
  stable
  attention
  at_risk
}

enum TaskStatus {
  pending
  in_progress
  waiting_client
  done
  cancelled
}

enum ChargeStatus {
  pending
  paid
  overdue
  cancelled
  refunded
}

enum ChargeType {
  one_time
  recurring
  hourly
}

enum PaymentMethod {
  pix
  boleto
  credit_card
  bank_transfer
  cash
}

enum AttendanceStatus {
  scheduled    // agendado
  closed       // fechou
  not_closed   // não fechou
  follow_up    // em follow-up
  no_show      // não compareceu
  rescheduled  // marcou para outra data
}

enum AttendancePaymentMethod {
  pix
  cash
  credit_card
}

enum AttendanceOrigin {
  meta_ads
  google_ads
  instagram
  google_organic
  referral     // indicação
  organic
  other
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedLeads    Lead[]         @relation("LeadOwner")
  assignedClients  Client[]       @relation("ClientOwner")
  assignedTasks    Task[]         @relation("TaskOwner")
  createdProposals Proposal[]     @relation("ProposalCreator")
  createdContracts Contract[]     @relation("ContractCreator")
  leadActivities   LeadActivity[]
  clientUser       ClientUser?
  auditLogs        AuditLog[]

  @@map("users")
}

// ─── CRM / Leads ──────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  status       LeadStatus @default(new)
  lostReason   String?
  nextFollowUp DateTime?
  notes        String?
  ownerId      String
  owner        User       @relation("LeadOwner", fields: [ownerId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  activities LeadActivity[]
  proposals  Proposal[]

  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  description String
  createdAt   DateTime @default(now())

  @@map("lead_activities")
}

// ─── Catálogo de Serviços ─────────────────────────────────────────────────────

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  services  Service[]

  @@map("service_categories")
}

model Service {
  id           String          @id @default(cuid())
  name         String
  description  String?
  categoryId   String
  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  defaultHours Decimal?        @db.Decimal(10, 2)
  defaultValue Decimal         @db.Decimal(10, 2)
  chargeType   ChargeType      @default(one_time)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  proposalItems ProposalItem[]

  @@map("service_catalog")
}

// ─── Propostas ────────────────────────────────────────────────────────────────

model Proposal {
  id         String         @id @default(cuid())
  token      String         @unique @default(cuid())
  title      String
  status     ProposalStatus @default(draft)
  leadId     String?
  lead       Lead?          @relation(fields: [leadId], references: [id])
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  creatorId  String
  creator    User           @relation("ProposalCreator", fields: [creatorId], references: [id])
  totalValue Decimal        @default(0) @db.Decimal(10, 2)
  validUntil DateTime?
  notes      String?
  acceptedAt DateTime?
  acceptedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  items    ProposalItem[]
  events   ProposalEvent[]
  contract Contract?

  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitValue   Decimal  @db.Decimal(10, 2)
  totalValue  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@map("proposal_items")
}

model ProposalEvent {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("proposal_events")
}

// ─── Contratos ────────────────────────────────────────────────────────────────

model Contract {
  id         String         @id @default(cuid())
  title      String
  status     ContractStatus @default(draft)
  proposalId String?        @unique
  proposal   Proposal?      @relation(fields: [proposalId], references: [id])
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id])
  creatorId  String
  creator    User           @relation("ContractCreator", fields: [creatorId], references: [id])
  startDate  DateTime?
  endDate    DateTime?
  value      Decimal?       @db.Decimal(10, 2)
  notes      String?
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  events  ContractEvent[]
  charges Charge[]

  @@map("contracts")
}

model ContractEvent {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("contract_events")
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  document     String?
  status       ClientStatus  @default(active)
  health       ClientHealth  @default(stable)
  healthNote   String?
  monthlyValue Decimal?      @db.Decimal(10, 2)
  startDate    DateTime?
  ownerId      String
  owner        User          @relation("ClientOwner", fields: [ownerId], references: [id])
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Métricas — credenciais de plataformas de anúncio
  metaAdAccountId     String?
  metaAccessToken     String?
  googleAdsCustomerId String?
  googleRefreshToken  String?

  // Metas mensais
  metaConvGoal        Int?     // meta mensal de conversas WhatsApp

  contacts        ClientContact[]
  clientUsers     ClientUser[]
  proposals       Proposal[]
  contracts       Contract[]
  tasks           Task[]
  charges         Charge[]
  healthLogs      ClientHealthLog[]
  metricEntries    ClientMetricEntry[]
  clientServices    ClientService[]
  attendances       Attendance[]
  whatsappAccounts  WhatsAppAccount[]
  whatsappCampaigns WhatsAppCampaign[]

  @@map("clients")
}

model ClientMetricEntry {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String   // "meta" | "google"
  date           String   // "2024-01-15" (YYYY-MM-DD)
  // Shared
  spend          Decimal? @db.Decimal(10, 2)
  impressions    Int?
  clicks         Int?
  leadsFromAds   Int?
  leadsScheduled Int?
  revenue        Decimal? @db.Decimal(10, 2)
  // Meta-specific
  reach          Int?
  cpm            Decimal? @db.Decimal(10, 4)
  linkClicks     Int?
  cpc            Decimal? @db.Decimal(10, 4)
  ctr            Decimal? @db.Decimal(10, 4)
  costPerResult  Decimal? @db.Decimal(10, 2)
  conversations  Int?
  budget         Decimal? @db.Decimal(10, 2)
  syncedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, platform, date])
  @@map("client_metric_entries")
}

model ClientHealthLog {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  health    ClientHealth
  note      String?
  createdAt DateTime     @default(now())

  @@map("client_health_logs")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("client_contacts")
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("client_users")
}

// ─── Tarefas ──────────────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus @default(pending)
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  assigneeId      String
  assignee        User       @relation("TaskOwner", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  isClientVisible Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  checklistItems TaskChecklistItem[]
  comments       TaskComment[]
  events         TaskEvent[]

  @@map("tasks")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("task_checklist_items")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  createdAt DateTime @default(now())

  @@map("task_comments")
}

model TaskEvent {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("task_events")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model Charge {
  id              String       @id @default(cuid())
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id])
  contractId      String?
  contract        Contract?    @relation(fields: [contractId], references: [id])
  description     String
  value           Decimal      @db.Decimal(10, 2)
  status          ChargeStatus  @default(pending)
  isRecurring     Boolean       @default(false)
  recurrenceDay   Int?
  paymentMethod   PaymentMethod @default(pix)
  dueDate         DateTime
  paidAt          DateTime?
  externalId      String?
  paymentLink     String?
  gatewayResponse Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  events ChargeEvent[]

  @@map("charges")
}

model ChargeEvent {
  id          String   @id @default(cuid())
  chargeId    String
  charge      Charge   @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("charge_events")
}

// ─── Atendimentos (portal do cliente) ────────────────────────────────────────

model ClientService {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances Attendance[]

  @@map("client_services")
}

model Attendance {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       ClientService?   @relation(fields: [serviceId], references: [id])
  valueQuoted   Decimal?         @db.Decimal(10, 2)
  valueClosed   Decimal?         @db.Decimal(10, 2)
  leadName      String?
  leadPhone     String?
  scheduledAt          DateTime?                 // data + hora do agendamento
  status               AttendanceStatus          @default(scheduled)
  lostReason           String?
  paymentMethod        AttendancePaymentMethod?  // pix / cash / credit_card
  paymentInstallments  Int?                      // parcelas (cartão)
  followUpCount Int              @default(0)
  origin        AttendanceOrigin @default(other)
  contactDate   DateTime         @default(now())
  period        String           // "2024-01"
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("attendances")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─── WhatsApp Business ────────────────────────────────────────────────────────

enum WhatsAppStatus {
  pending
  active
  disconnected
}

model WhatsAppAccount {
  id            String          @id @default(cuid())
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phoneNumber   String          // +5511999999999 (display)
  phoneNumberId String          @unique // Meta's Phone Number ID
  displayName   String?
  accessToken   String          // Meta System User Token or page token
  wabaId        String?         // WhatsApp Business Account ID
  status        WhatsAppStatus  @default(pending)
  verifiedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  conversations WhatsAppConversation[]
  campaigns     WhatsAppCampaign[]

  @@map("whatsapp_accounts")
}

model WhatsAppCampaign {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  whatsAppAccountId String?
  whatsAppAccount   WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id])
  name                  String           // "Campanha Implante Dezembro"
  origin                AttendanceOrigin // meta_ads, instagram, google_ads, etc.
  campaignCode          String           @unique // 6-char code embedded in message [ref:abc123]
  defaultMessage        String           // pre-filled WhatsApp message (without [ref:...])
  adPlatformCampaignId  String?          // Meta campaign ID or Google campaign ID
  adPlatformCampaignName String?         // human-readable name from the platform
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())

  @@map("whatsapp_campaigns")
}

model WhatsAppConversation {
  id           String          @id @default(cuid())
  accountId    String
  account      WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  from         String          // sender phone number (hashed for privacy)
  firstMessage String?         // first message text (trimmed to 200 chars)
  campaignRef  String?         // extracted from message if present (UTM etc.)
  date         String          // YYYY-MM-DD for aggregation
  startedAt    DateTime        @default(now())

  @@index([accountId, date])
  @@map("whatsapp_conversations")
}
