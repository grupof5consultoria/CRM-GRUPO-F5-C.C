generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  operations_manager
  sales
  finance
  operations
  client_admin
  client_team
  client_viewer
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal_sent
  negotiation
  closed_won
  closed_lost
  onboarding
  active_client
  upsell_opportunity
  at_risk_churn
  churned
}

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum ContractStatus {
  draft
  pending_signature
  active
  paused
  cancelled
  finished
  pending_cancellation
}

enum ClientStatus {
  active
  inactive
  blocked
}

enum ClientHealth {
  thriving
  stable
  attention
  at_risk
}

enum TaskStatus {
  pending
  in_progress
  waiting_client
  done
  cancelled
}

enum ChargeStatus {
  pending
  paid
  overdue
  cancelled
  refunded
}

enum ChargeType {
  one_time
  recurring
  hourly
}

enum PaymentMethod {
  pix
  boleto
  credit_card
  bank_transfer
  cash
}

enum AttendanceStatus {
  scheduled    // agendado
  closed       // fechou
  not_closed   // não fechou
  follow_up    // em follow-up
  no_show      // não compareceu
  rescheduled  // marcou para outra data
}

enum AttendancePaymentMethod {
  pix
  cash
  credit_card
}

enum AttendanceOrigin {
  meta_ads
  google_ads
  instagram
  google_organic
  referral     // indicação
  organic
  other
}

enum PatientLeadStatus {
  novo_lead           // entrou pelo tráfego
  em_contato          // equipe entrou em contato
  agendado            // consulta marcada
  consulta_realizada  // paciente compareceu
  proposta_enviada    // proposta de tratamento enviada
  fechado             // tratamento fechado/pago
  perdido             // não converteu
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedLeads       Lead[]         @relation("LeadOwner")
  assignedClients     Client[]       @relation("ClientOwner")
  assignedTasks       Task[]         @relation("TaskOwner")
  createdProposals    Proposal[]     @relation("ProposalCreator")
  createdContracts    Contract[]     @relation("ContractCreator")
  leadActivities      LeadActivity[]
  clientUser          ClientUser?
  auditLogs           AuditLog[]
  assignedPatientLeads PatientLead[] @relation("PatientLeadAssignee")

  @@map("users")
}

// ─── CRM / Leads ──────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  status       LeadStatus @default(new)
  lostReason   String?
  nextFollowUp DateTime?
  notes        String?
  value        Decimal?   @db.Decimal(12, 2)
  source       String?
  platforms    String[]
  ownerId      String
  owner        User       @relation("LeadOwner", fields: [ownerId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  activities LeadActivity[]
  proposals  Proposal[]

  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  description String
  createdAt   DateTime @default(now())

  @@map("lead_activities")
}

// ─── Catálogo de Serviços ─────────────────────────────────────────────────────

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  services  Service[]

  @@map("service_categories")
}

model Service {
  id           String          @id @default(cuid())
  name         String
  description  String?
  categoryId   String
  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  defaultHours Decimal?        @db.Decimal(10, 2)
  defaultValue Decimal         @db.Decimal(10, 2)
  chargeType   ChargeType      @default(one_time)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  proposalItems ProposalItem[]

  @@map("service_catalog")
}

// ─── Propostas ────────────────────────────────────────────────────────────────

model Proposal {
  id         String         @id @default(cuid())
  token      String         @unique @default(cuid())
  title      String
  status     ProposalStatus @default(draft)
  leadId     String?
  lead       Lead?          @relation(fields: [leadId], references: [id])
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  creatorId  String
  creator    User           @relation("ProposalCreator", fields: [creatorId], references: [id])
  totalValue Decimal        @default(0) @db.Decimal(10, 2)
  validUntil DateTime?
  notes      String?
  acceptedAt DateTime?
  acceptedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  items    ProposalItem[]
  events   ProposalEvent[]
  contract Contract?

  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitValue   Decimal  @db.Decimal(10, 2)
  totalValue  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@map("proposal_items")
}

model ProposalEvent {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("proposal_events")
}

// ─── Contratos ────────────────────────────────────────────────────────────────

model Contract {
  id         String         @id @default(cuid())
  title      String
  status     ContractStatus @default(draft)
  proposalId String?        @unique
  proposal   Proposal?      @relation(fields: [proposalId], references: [id])
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id])
  creatorId  String
  creator    User           @relation("ContractCreator", fields: [creatorId], references: [id])
  startDate  DateTime?
  endDate    DateTime?
  value      Decimal?       @db.Decimal(10, 2)
  notes      String?
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Template variables (F5 contract)
  meses               Int?
  plano               String?    // "START", "SCALE", etc.
  diaVencimento       Int?
  publicoAlvo         String?
  nomeContratante     String?
  cpfContratante      String?
  enderecoContratante String?
  cidadeEstadoCep     String?
  valorMensalExtenso  String?
  servicos            String[]  // lista de serviços incluídos na cláusula 1.2

  // Encerramento / Finalização
  finishReason  String?
  finishNote    String?

  // Cancelamento
  cancelReason  String?
  cancelNote    String?

  // Digital signature
  signedToken      String    @unique @default(cuid())
  signedByName     String?
  signedByCpf      String?
  signedIp         String?

  // Distrato (termination agreement)
  distratoToken        String?   @unique @default(cuid())
  distratoSignedAt     DateTime?
  distratoSignedByName String?
  distratoSignedByCpf  String?
  distratoSignedIp     String?

  events  ContractEvent[]
  charges Charge[]

  @@map("contracts")
}

model ContractEvent {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("contract_events")
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  document     String?
  status       ClientStatus  @default(active)
  health       ClientHealth  @default(stable)
  healthNote   String?
  monthlyValue Decimal?      @db.Decimal(10, 2)
  startDate    DateTime?
  ownerId      String
  owner        User          @relation("ClientOwner", fields: [ownerId], references: [id])
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Métricas — credenciais de plataformas de anúncio
  metaAdAccountId     String?
  metaAccessToken     String?
  googleAdsCustomerId String?
  googleRefreshToken  String?

  source              String?  // indicacao, google, anuncio, instagram, organico, outro

  // Metas mensais
  metaConvGoal        Int?     // meta mensal de conversas WhatsApp
  metaFaturamento     Decimal? @db.Decimal(12, 2) // meta mensal de faturamento

  // Churn / encerramento
  churnReason   String?   // motivo da saída (enum textual)
  churnNote     String?   // observação livre
  churnedAt     DateTime? // quando foi encerrado

  contacts        ClientContact[]
  clientUsers     ClientUser[]
  proposals       Proposal[]
  contracts       Contract[]
  tasks           Task[]
  charges         Charge[]
  healthLogs      ClientHealthLog[]
  metricEntries    ClientMetricEntry[]
  clientServices    ClientService[]
  attendances       Attendance[]
  whatsappAccounts  WhatsAppAccount[]
  whatsappCampaigns WhatsAppCampaign[]
  onboardingTasks   OnboardingTask[]
  strategies        Strategy[]
  trafficSettings      TrafficSettings?
  trafficTasks         TrafficTask[]
  campaignOptimizations CampaignOptimization[]
  audienceUpdates      AudienceUpdate[]
  instagramTracking    InstagramTracking[]
  landingPageProject   LandingPageProject?
  patientLeads         PatientLead[]
  commercialProposals  CommercialProposal[]

  @@map("clients")
}

model ClientMetricEntry {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String   // "meta" | "google"
  date           String   // "2024-01-15" (YYYY-MM-DD)
  // Shared
  spend          Decimal? @db.Decimal(10, 2)
  impressions    Int?
  clicks         Int?
  leadsFromAds   Int?
  leadsScheduled Int?
  revenue        Decimal? @db.Decimal(10, 2)
  // Meta-specific
  reach          Int?
  cpm            Decimal? @db.Decimal(10, 4)
  linkClicks     Int?
  cpc            Decimal? @db.Decimal(10, 4)
  ctr            Decimal? @db.Decimal(10, 4)
  costPerResult  Decimal? @db.Decimal(10, 2)
  conversations  Int?
  budget         Decimal? @db.Decimal(10, 2)
  syncedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, platform, date])
  @@map("client_metric_entries")
}

model ClientHealthLog {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  health    ClientHealth
  note      String?
  createdAt DateTime     @default(now())

  @@map("client_health_logs")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("client_contacts")
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("client_users")
}

// ─── Tarefas ──────────────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus @default(pending)
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  assigneeId      String
  assignee        User       @relation("TaskOwner", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  isClientVisible Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  checklistItems TaskChecklistItem[]
  comments       TaskComment[]
  events         TaskEvent[]

  @@map("tasks")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("task_checklist_items")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  createdAt DateTime @default(now())

  @@map("task_comments")
}

model TaskEvent {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("task_events")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model Charge {
  id              String       @id @default(cuid())
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id])
  contractId      String?
  contract        Contract?    @relation(fields: [contractId], references: [id])
  description     String
  value           Decimal      @db.Decimal(10, 2)
  status          ChargeStatus  @default(pending)
  isRecurring     Boolean       @default(false)
  recurrenceDay   Int?
  paymentMethod   PaymentMethod @default(pix)
  dueDate         DateTime
  paidAt          DateTime?
  externalId      String?
  paymentLink     String?
  gatewayResponse Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  events ChargeEvent[]

  @@map("charges")
}

model ChargeEvent {
  id          String   @id @default(cuid())
  chargeId    String
  charge      Charge   @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@map("charge_events")
}

// ─── Atendimentos (portal do cliente) ────────────────────────────────────────

model ClientService {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances Attendance[]

  @@map("client_services")
}

model Attendance {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       ClientService?   @relation(fields: [serviceId], references: [id])
  valueQuoted   Decimal?         @db.Decimal(10, 2)
  valueClosed   Decimal?         @db.Decimal(10, 2)
  leadName      String?
  leadPhone     String?
  scheduledAt          DateTime?                 // data + hora do agendamento
  status               AttendanceStatus          @default(scheduled)
  lostReason           String?
  paymentMethod        AttendancePaymentMethod?  // pix / cash / credit_card
  paymentInstallments  Int?                      // parcelas (cartão)
  followUpCount Int              @default(0)
  origin        AttendanceOrigin @default(other)
  contactDate   DateTime         @default(now())
  period        String           // "2024-01"
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("attendances")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─── WhatsApp Business ────────────────────────────────────────────────────────

enum WhatsAppStatus {
  pending
  active
  disconnected
}

model WhatsAppAccount {
  id            String          @id @default(cuid())
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phoneNumber   String          // +5511999999999 (display)
  phoneNumberId String          @unique // Meta's Phone Number ID
  displayName   String?
  accessToken   String          // Meta System User Token or page token
  wabaId        String?         // WhatsApp Business Account ID
  status        WhatsAppStatus  @default(pending)
  verifiedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  conversations WhatsAppConversation[]
  campaigns     WhatsAppCampaign[]

  @@map("whatsapp_accounts")
}

model WhatsAppCampaign {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  whatsAppAccountId String?
  whatsAppAccount   WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id])
  name                  String           // "Campanha Implante Dezembro"
  origin                AttendanceOrigin // meta_ads, instagram, google_ads, etc.
  campaignCode          String           @unique // 6-char code embedded in message [ref:abc123]
  defaultMessage        String           // pre-filled WhatsApp message (without [ref:...])
  adPlatformCampaignId  String?          // Meta campaign ID or Google campaign ID
  adPlatformCampaignName String?         // human-readable name from the platform
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())

  @@map("whatsapp_campaigns")
}

model WhatsAppConversation {
  id           String          @id @default(cuid())
  accountId    String
  account      WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  from         String          // sender phone number (hashed for privacy)
  firstMessage String?         // first message text (trimmed to 200 chars)
  campaignRef  String?         // extracted from message if present (UTM etc.)
  date         String          // YYYY-MM-DD for aggregation
  startedAt    DateTime        @default(now())

  @@index([accountId, date])
  @@map("whatsapp_conversations")
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model OnboardingTask {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stepNumber  Int
  title       String
  status      String    @default("pending")  // pending | in_progress | done
  assignedTo  String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  data        Json?     // checklist items and extra fields per step

  @@map("onboarding_tasks")
}

// ─── Tráfego Pago ─────────────────────────────────────────────────────────────

model TrafficSettings {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platforms     String[] // ["meta_ads", "google_ads"]
  caMeta        String?  // Conta de Anúncios Meta
  caGoogle      String?  // Conta de Anúncios Google
  dailyBudget   Decimal? @db.Decimal(10, 2)
  monthlyBudget Decimal? @db.Decimal(10, 2)
  driveLink     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("traffic_settings")
}

model TrafficTask {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String    // "optimization_daily" | "optimization_weekly" | "optimization_monthly" | "report_weekly" | "report_monthly" | "measurement" | "audience_update" | "instagram_check"
  title       String
  frequency   String?   // "daily" | "weekly" | "monthly"
  assignedTo  String?
  status      String    @default("pending") // "pending" | "done" | "skipped"
  comment     String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("traffic_tasks")
}

model CampaignOptimization {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date          String   // "YYYY-MM-DD"
  platform      String   // "meta" | "google" | "both"
  campaignName  String?
  description   String?
  frequencyType String?  // "daily" | "weekly" | "monthly"
  assignedTo    String?
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("campaign_optimizations")
}

model AudienceUpdate {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  audienceType String   // "videoview" | "remarketing"
  name         String   // e.g. "Visualizou 75% do vídeo", "Visitou página de serviços"
  windowDays   Int?     // optional: 30 | 60 | 90 | 180 | 365
  assignedTo   String?
  comment      String?
  lastUpdated  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("audience_updates")
}

model InstagramTracking {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weekReference String   // "YYYY-WNN" e.g. "2024-W15"
  postedDaily   String?  // "yes" | "no" | "partial"
  postedWeekly  Boolean?
  assignedTo    String?
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, weekReference])
  @@map("instagram_tracking")
}

// ─── Landing Page ─────────────────────────────────────────────────────────────

model LandingPageProject {
  id             String   @id @default(cuid())
  clientId       String   @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyName    String
  services       String?
  colorPrimary   String?
  colorSecondary String?
  references     String?
  domain         String?
  hasDomain      Boolean  @default(false)
  businessHours  String?
  businessDays   String[]
  wantsBlog      Boolean  @default(false)
  purpose        String?  // "ads" | "organic" | "both"
  progress       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  phases LandingPagePhase[]

  @@map("landing_page_projects")
}

model LandingPagePhase {
  id          String             @id @default(cuid())
  projectId   String
  project     LandingPageProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseNumber Int
  title       String
  status      String             @default("not_started")
  assignedTo  String?
  startedAt   DateTime?
  completedAt DateTime?
  comment     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([projectId, phaseNumber])
  @@map("landing_page_phases")
}

// ─── CRM Cliente (leads de tráfego pago das doutoras) ────────────────────────

model PatientLead {
  id             String            @id @default(cuid())
  clientId       String
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  status         PatientLeadStatus @default(novo_lead)
  origin         AttendanceOrigin  @default(other)
  treatmentValue Decimal?          @db.Decimal(10, 2)
  lostReason     String?
  scheduledAt    DateTime?
  notes          String?
  source         String?           // campanha, anúncio, UTM, etc.
  assigneeId     String?
  assignee       User?             @relation("PatientLeadAssignee", fields: [assigneeId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("patient_leads")
}

// ─── Estratégias ──────────────────────────────────────────────────────────────

model Strategy {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month     String   // "2026-04" (YYYY-MM)
  nodes     Json     // MindNode tree JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, month])
  @@map("strategies")
}

// ─── Agência (wiki interna + equipe + proposta comercial) ─────────────────────

enum TeamMemberStatus {
  active
  vacation
  dismissed
}

enum TeamMemberRole {
  sdr
  closer
  cs
  traffic_manager
  designer
  manager
  other
}

model AgencyTeamMember {
  id          String           @id @default(cuid())
  name        String
  role        TeamMemberRole
  email       String?
  whatsapp    String?
  status      TeamMemberStatus @default(active)
  joinedAt    DateTime?
  dismissedAt DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  offboarding AgencyOffboarding[]

  @@map("agency_team_members")
}

model AgencyOffboarding {
  id          String           @id @default(cuid())
  memberId    String
  member      AgencyTeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessItem  String           // drive | meta | google_mcc | analytics | etc.
  label       String
  revoked     Boolean          @default(false)
  revokedAt   DateTime?
  responsible String?
  createdAt   DateTime         @default(now())

  @@map("agency_offboarding")
}

model AgencyMeeting {
  id           String    @id @default(cuid())
  type         String    // weekly | monthly
  scheduledAt  DateTime?
  participants String[]
  meetingLink  String?
  status       String    @default("scheduled") // scheduled | done | cancelled
  summary      String?
  nextSteps    String?
  responsible  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("agency_meetings")
}

model AgencyWikiPage {
  id        String   @id @default(cuid())
  section   String   // services | processes | educational
  slug      String
  title     String
  content   String?
  links     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, slug])
  @@map("agency_wiki_pages")
}

model CommercialProposal {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan            String   // start | scale
  priceImpl       Decimal  @db.Decimal(10, 2)
  priceMonthly    Decimal  @db.Decimal(10, 2)
  discountApplied Boolean  @default(false)
  adBudget        Decimal? @db.Decimal(10, 2)
  status          String   @default("draft") // draft | sent | accepted | rejected | expired
  notes           String?
  sentAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("commercial_proposals")
}
